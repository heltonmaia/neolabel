# Backend
DATA_DIR=./data
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
FRONTEND_URL=http://localhost:5173
BACKEND_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000/api/v1

# Google Sign-In (public OAuth 2.0 Web client ID — no secret)
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Emergency access (Google-independent fallback if OAuth is unavailable or
# misconfigured). Visiting /emergency emails a one-time code via Resend to
# EMERGENCY_ADMIN_EMAIL; entering it signs in as that admin.
RESEND_API_KEY=
EMAIL_FROM=NeoLabel <noreply@example.com>
EMERGENCY_ADMIN_EMAIL=
