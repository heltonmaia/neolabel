# Backend
DATA_DIR=./data
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
FRONTEND_URL=http://localhost:5173
BACKEND_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000/api/v1

# Google Sign-In (public OAuth 2.0 Web client ID — no secret)
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Break-glass local admin (emergency access if OAuth is misconfigured).
# Setting BOTH of these seeds a real password admin on startup — leave
# BREAKGLASS_ADMIN_PASSWORD blank unless you actually want one live.
BREAKGLASS_ADMIN_EMAIL=admin@example.com
BREAKGLASS_ADMIN_PASSWORD=
