# Production env — copy to .env.prod on the VPS and edit.
# Load with: docker compose --env-file .env.prod -f docker-compose.prod.yml up -d

# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=

# Public URL the browser uses (used for CORS). No trailing slash.
FRONTEND_URL=https://label.example.com

# JWT lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Where project data lives on the host (bind-mounted into the backend at /data)
DATA_DIR=/srv/neo-label/data

# Port bound to 127.0.0.1 on the host — the host nginx reverse-proxies HTTPS here
FRONTEND_PORT=8080

# Google Sign-In — public OAuth 2.0 Web client ID (no secret needed).
# VITE_GOOGLE_CLIENT_ID is embedded at BUILD time, so it must be set when
# the frontend image is built (deploy.sh rebuilds).
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Break-glass local admin — the only password account. Use a strong value.
BREAKGLASS_ADMIN_EMAIL=
BREAKGLASS_ADMIN_PASSWORD=
